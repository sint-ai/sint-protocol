{
  "name": "@sint/mcp",
  "version": "0.1.0",
  "description": "SINT MCP — Security-first multi-MCP proxy server with policy enforcement",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sint-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sint/bridge-mcp": "workspace:*",
    "@sint/core": "workspace:*",
    "@sint/gate-capability-tokens": "workspace:*",
    "@sint/gate-evidence-ledger": "workspace:*",
    "@sint/gate-policy-gateway": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
