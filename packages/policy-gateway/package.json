{
  "name": "@sint/gate-policy-gateway",
  "version": "0.1.0",
  "description": "SINT Gate — Policy Gateway: the single choke point for all agent actions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "bench": "vitest bench"
  },
  "dependencies": {
    "@sint/core": "workspace:*",
    "@sint/gate-capability-tokens": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@sint/gate-evidence-ledger": "workspace:*",
    "@sint/persistence": "workspace:*",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
