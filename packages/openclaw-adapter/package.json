{
  "name": "@sint-ai/openclaw-adapter",
  "version": "0.1.0",
  "description": "SINT Protocol adapter for OpenClaw — injects capability token governance into every OpenClaw tool call, MCP server, and node action.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "sint",
    "openclaw",
    "ai-safety",
    "governance",
    "capability-tokens",
    "policy-gateway",
    "mcp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sint-ai/sint-protocol.git",
    "directory": "packages/openclaw-adapter"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pshkv/client": "workspace:*",
    "@pshkv/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
