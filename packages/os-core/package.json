{
  "name": "@pshkv/os-core",
  "version": "0.1.0",
  "description": "SINT OS Core — unified entrypoint for the SINT Operating System. Combines OpenClaw runtime, SINT Protocol governance, avatar face, and multimodal bridge.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "sint",
    "sint-os",
    "ai-os",
    "jarvis",
    "governance",
    "multimodal",
    "agent-runtime",
    "openclaw",
    "physical-ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sint-ai/sint-protocol.git",
    "directory": "packages/os-core"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@pshkv/client": "workspace:*",
    "@pshkv/core": "workspace:*",
    "@pshkv/openclaw-adapter": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
