{
  "name": "@pshkv/bridge-ros2",
  "version": "0.1.0",
  "description": "SINT Bridge \u2014 ROS 2 adapter: intercepts robot topic publishes and service calls through the security gate",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@pshkv/core": "workspace:*",
    "@pshkv/gate-capability-tokens": "workspace:*",
    "@pshkv/gate-policy-gateway": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sint-ai/sint-protocol",
    "directory": "packages/bridge-ros2"
  }
}
