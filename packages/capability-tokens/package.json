{
  "name": "@sint/gate-capability-tokens",
  "version": "0.1.0",
  "description": "SINT Gate — Capability token issuance, validation, delegation, and revocation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@sint/core": "workspace:*",
    "@noble/ed25519": "^2.2.0",
    "@noble/hashes": "^1.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sint-ai/sint-protocol",
    "directory": "packages/capability-tokens"
  },
  "homepage": "https://github.com/sint-ai/sint-protocol#readme",
  "bugs": {
    "url": "https://github.com/sint-ai/sint-protocol/issues"
  },
  "license": "Apache-2.0"
}
