{
  "name": "@pshkv/bridge-city",
  "version": "0.1.0",
  "description": "SINT Bridge — Smart City Governance: FIWARE/NGSI-LD integration with citizen consent management and civic evidence ledgers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@pshkv/core": "workspace:*",
    "@pshkv/gate-capability-tokens": "workspace:*",
    "@pshkv/gate-policy-gateway": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sint-ai/sint-protocol",
    "directory": "packages/bridge-city"
  },
  "homepage": "https://github.com/sint-ai/sint-protocol#readme",
  "bugs": {
    "url": "https://github.com/sint-ai/sint-protocol/issues"
  },
  "license": "Apache-2.0",
  "keywords": [
    "sint",
    "smart-city",
    "fiware",
    "ngsi-ld",
    "civic-governance",
    "citizen-consent",
    "municipal-ai"
  ]
}
