{
  "name": "@pshkv/core",
  "version": "0.1.0",
  "description": "SINT Protocol core types, schemas, and constants",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sint-ai/sint-protocol",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/sint-ai/sint-protocol#readme",
  "bugs": {
    "url": "https://github.com/sint-ai/sint-protocol/issues"
  },
  "license": "Apache-2.0"
}
