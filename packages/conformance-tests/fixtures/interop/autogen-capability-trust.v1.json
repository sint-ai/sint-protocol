        "decisionAction": "deny",
        "policyViolated": "TRUST_BLOCKED",
        "expectedEvidenceEvent": "economy.trust.blocked"
      }
    }
  ],
  "edgeFailClosedScenario": {
    "name": "edge disconnect denies trust-escalated T2 action",
    "request": {
      "resource": "mcp://autogen/planner/summarize",
      "action": "call",
      "params": {}
    },
    "trustSignal": "medium_risk",
    "expected": {
      "assignedTier": "T3_commit",
      "decisionAction": "deny",
      "policyViolated": "EDGE_CENTRAL_UNAVAILABLE"
    }
  }
