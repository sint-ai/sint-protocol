{
  "name": "@sint-ai/bridge-mavlink",
  "version": "0.1.0",
  "description": "SINT Protocol MAVLink bridge \u2014 UAV/drone command interception and safety enforcement",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@pshkv/core": "workspace:*",
    "@pshkv/gate-policy-gateway": "workspace:*"
  },
  "devDependencies": {
    "@pshkv/gate-capability-tokens": "workspace:*",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sint-ai/sint-protocol",
    "directory": "packages/bridge-mavlink"
  }
}
